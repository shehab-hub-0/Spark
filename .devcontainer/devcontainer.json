{
  // ============================================================================
  // VS Code Dev Container Configuration
  // PySpark 3.5.0 | Single-Node Local Mode | 12 GB RAM / 6 CPU
  // ============================================================================
  "name": "PySpark 3.5.0 Dev Environment",

  // ── Build ────────────────────────────────────────────────────────────────────
  // Build from the Dockerfile at the project root
  "build": {
    "dockerfile": "../Dockerfile",
    // Context is the project root so COPY in Dockerfile resolves correctly
    "context": ".."
  },

  // ── Runtime user ─────────────────────────────────────────────────────────────
  // Must match the non-root user created in Dockerfile (UID 1000)
  "remoteUser": "sparkdev",

  // ── Container user at creation time ──────────────────────────────────────────
  // Root is needed during postCreateCommand to fix any mount permissions
  "containerUser": "sparkdev",

  // ── Workspace mount ──────────────────────────────────────────────────────────
  // Bind-mounts your local project root into /workspace inside the container.
  // "consistency: cached" improves I/O performance on macOS hosts.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",

  // ── Port forwarding ──────────────────────────────────────────────────────────
  // Spark UI (4040) auto-forwarded so you can inspect job DAGs in your browser
  "forwardPorts": [4040],
  "portsAttributes": {
    "4040": {
      "label": "Spark UI",
      "onAutoForward": "notify"
    }
  },

  // ── Environment variables inside the container ────────────────────────────────
  "remoteEnv": {
    "SPARK_HOME": "/opt/spark",
    "PYSPARK_PYTHON": "python3",
    "PYSPARK_DRIVER_PYTHON": "python3",
    "PYTHONPATH": "/opt/spark/python:/opt/spark/python/lib/py4j-0.10.9.7-src.zip",
    "SPARK_LOCAL_IP": "127.0.0.1"
  },

  // ── VS Code Extensions ───────────────────────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        // ── Python core ──────────────────────────────────────────────────────
        "ms-python.python",           // Python language support
        "ms-python.pylance",          // Fast, feature-rich IntelliSense (Pylance)
        "ms-python.black-formatter",  // Black code formatter
        "ms-python.isort",            // Import sorting
        "ms-python.flake8",           // Linting

        // ── Type checking ────────────────────────────────────────────────────
        "ms-pyright.pyright",         // Static type checker (complements Pylance)

        // ── Testing ──────────────────────────────────────────────────────────
        "ms-python.vscode-pytest",    // Pytest integration (test explorer)

        // ── Git ──────────────────────────────────────────────────────────────
        "eamodio.gitlens",            // Supercharged Git: blame, history, diffs
        "mhutchie.git-graph",         // Visual Git graph

        // ── Editor quality-of-life ────────────────────────────────────────────
        "streetsidesoftware.code-spell-checker",
        "usernamehw.errorlens",       // Inline error/warning display
        "mechatroner.rainbow-csv",    // Colorized CSV viewing
        "ms-vscode.live-share",       // Optional: collaborative editing

        // ── Container / Docker awareness ─────────────────────────────────────
        "ms-azuretools.vscode-docker" // Docker file support inside container
      ],

      // ── VS Code workspace settings ─────────────────────────────────────────
      "settings": {
        // Python interpreter: point to the system python3 with PySpark installed
        "python.defaultInterpreterPath": "/usr/bin/python3",

        // Pylance — strict mode for maximum type safety during development
        "python.languageServer": "Pylance",
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.indexing": true,

        // Extra paths so Pylance resolves PySpark types correctly
        "python.analysis.extraPaths": [
          "/opt/spark/python",
          "/opt/spark/python/lib/py4j-0.10.9.7-src.zip"
        ],

        // Formatter: Black
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "black-formatter.args": ["--line-length", "100"],
        "isort.args": ["--profile", "black", "--line-length", "100"],

        // Linting
        "flake8.args": ["--max-line-length=100", "--extend-ignore=E203,W503"],

        // Testing
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "python.testing.cwd": "/workspace",

        // Editor experience
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.rulers": [100],
        "editor.renderWhitespace": "boundary",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,

        // Terminal defaults
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "SPARK_HOME": "/opt/spark",
          "PYSPARK_PYTHON": "python3",
          "PYTHONPATH": "/opt/spark/python:/opt/spark/python/lib/py4j-0.10.9.7-src.zip"
        }
      }
    }
  },

  // ── Post-create command ───────────────────────────────────────────────────────
  // Runs once after the container is first created.
  // Ensures /workspace has the right permissions (important after bind mount).
  "postCreateCommand": "sudo chown -R sparkdev:1000 /workspace /tmp/spark-events /tmp/spark-warehouse 2>/dev/null || true && echo '✅ Dev Container ready! Open src/main.py and press F5 or run: python src/main.py'",

  // ── Features ──────────────────────────────────────────────────────────────────
  // Dev Container Features provide additional tooling in a composable way
  "features": {
    // Common utilities (jq, zip, etc.)
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false,
      "installOhMyZsh": false,
      "upgradePackages": false
    },
    // Git — ensures latest Git is always available
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "latest"
    }
  },

  // ── Keep container running ───────────────────────────────────────────────────
  // overrideCommand ensures the CMD from the Dockerfile ("sleep infinity") is
  // used, which keeps the container alive for VS Code to attach to.
  "overrideCommand": false,

  // ── Shutdown action ──────────────────────────────────────────────────────────
  // When the VS Code window is closed, stop (not destroy) the container.
  // Your work persists; the container restarts instantly next time.
  "shutdownAction": "stopContainer"
}

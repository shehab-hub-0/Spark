# ================================================================
# Data Platform — Environment Variables
# IMPORTANT: Never commit this file to git! Add .env to .gitignore
# ================================================================

# ── PostgreSQL ───────────────────────────────────────────────────
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=postgres
POSTGRES_VERSION=16

# ── MinIO ────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Redis ────────────────────────────────────────────────────────
REDIS_VERSION=7.2-bookworm

# ── Conduktor ────────────────────────────────────────────────────
CONDUKTOR_PG_PASSWORD=some_password

# ── Spark ────────────────────────────────────────────────────────
SPARK_VERSION=3.5.0
SPARK_MASTER_DAEMON_MEM=384m
SPARK_WORKER_CORES=6
SPARK_WORKER_MEM=6144m

# ── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@platform.local
PGADMIN_PASSWORD=admin

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Airflow ──────────────────────────────────────────────────────
# Generate a real key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=changeme-use-random-string-in-production
AIRFLOW_UID=1000

# ── Superset ─────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=changeme-superset-secret-in-production

# ── Docker Host ──────────────────────────────────────────────────
DOCKER_HOST_IP=127.0.0.1
# ── Kafka Host ──────────────────────────────────────────────────
KAFKA_HOST_IP=127.0.0.1 
KAFKA_PASSWORD = dhdgfEFT8564@#FRF
# ── Jupyter ──────────────────────────────────────────────────────
JUPYTER_TOKEN=admin

# ── OpenMetadata ─────────────────────────────────────────────────
OPENMETADATA_DB_USER=openmetadata
OPENMETADATA_DB_PASSWORD=openmetadata

# ── Airflow Init ─────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ── Superset Init ────────────────────────────────────────────────
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# ── ClickHouse ───────────────────────────────────────────────────
CLICKHOUSE_ADMIN_PASSWORD=admin


# ================================================================
# Data Platform — Environment Variables Template
# Copy this file to .env and fill in the values before running docker-compose
# ================================================================

# ── PostgreSQL ───────────────────────────────────────────────────
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here
PG_DB=postgres
POSTGRES_VERSION=16

# ── MinIO ────────────────────────────────────────────────────────
MINIO_ROOT_USER=your_minio_root_user_here
MINIO_ROOT_PASSWORD=your_minio_root_password_here

# ── Redis ────────────────────────────────────────────────────────
REDIS_VERSION=7.2-bookworm

# ── Conduktor ────────────────────────────────────────────────────
CONDUKTOR_PG_PASSWORD=your_conduktor_pg_password_here

# ── Spark ────────────────────────────────────────────────────────
SPARK_VERSION=3.5.0
SPARK_MASTER_DAEMON_MEM=384m
SPARK_WORKER_CORES=6
SPARK_WORKER_MEM=6144m

# ── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@platform.local
PGADMIN_PASSWORD=your_pgadmin_password_here

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here

# ── Airflow ──────────────────────────────────────────────────────
# Generate a real key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_airflow_fernet_key_here
AIRFLOW_SECRET_KEY=your_airflow_secret_key_here
AIRFLOW_UID=50000

# ── Superset ─────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=your_superset_secret_key_here

# ── Docker Host ──────────────────────────────────────────────────
DOCKER_HOST_IP=127.0.0.1
